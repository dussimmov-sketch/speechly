import os
from telegram import Update
from telegram.ext import ApplicationBuilder, MessageHandler, CommandHandler, filters, ContextTypes

TOKEN = os.getenv("8764481892:AAECEQkH6LRAgM6D9Qm0xK6es3BsD6RW9K8")

bad_words = ["тупой", "идиот", "дурак"]

replacements = {
    "тупой": "неправ",
    "идиот": "человек с другим мнением",
    "дурак": "ошибаешься"
}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Привет! Я бот, который делает речь более культурной 😊\n\n"
        "Напиши сообщение, и я его проверю!"
    )

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.lower()

    found = 0

    for word in bad_words:
        if word in text:
            text = text.replace(word, replacements[word])
            found += 1

    if found > 0:
        await update.message.reply_text(f"Исправленный вариант:\n{text}")
    else:
        await update.message.reply_text("Всё отлично 👍")

app = ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT, handle_message))

app.run_polling()
